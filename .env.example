# =============================================================================
# DBFox 环境变量模板
# 复制此文件为 .env 并填入你的实际配置值。
#   cp .env.example .env
# =============================================================================

# ---- LLM 配置 ----
# API 密钥（必填）。兼容 OpenAI / Qwen / DeepSeek 等接口。
OPENAI_API_KEY=sk-your-api-key-here

# 自定义 API Base URL（可选，默认 https://api.openai.com/v1）。
# 示例: Qwen → https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- LangSmith 追踪（可选） ----
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=dbfox
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- 引擎运行时 ----
# 后端端口（默认 18625，一般无需修改）
# DBFOX_ENGINE_PORT=18625

# 自定义运行时数据目录（默认 Windows: %APPDATA%/dbfox, Linux: ~/.local/share/dbfox）
# DBFOX_RUNTIME_DIR=

# 元数据库 URL（默认使用 SQLite，自动创建在运行时目录）
# DBFOX_DATABASE_URL=

# ---- Agent 配置（可选） ----
# Agent 持久化模式: sync (默认) | async
# AGENT_PERSISTENCE_MODE=sync

# Checkpointer 模式: sqlite (默认) | memory
# DBFOX_AGENT_CORE_CHECKPOINTER=sqlite

# ---- 测试 ——
# DBFOX_TESTING=1  # 仅 CI / 测试环境启用
